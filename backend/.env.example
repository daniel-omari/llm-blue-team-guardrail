# Copy to .env and fill in. All values are optional for local/demo use.

# Postgres connection (omit to run without request logging)
DATABASE_URL=postgresql+psycopg://guardrail:guardrail@localhost:5432/guardrail

# Hosted-LLM judge (omit to run heuristics-only)
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# Frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:5173
